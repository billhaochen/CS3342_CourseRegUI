<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import org.controlsfx.control.CheckComboBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="CourseRegisterUI.controllers.CreateAccountController">

    <children>
        <VBox fx:id="createAccountBox"
              maxWidth="820"
              prefWidth="820"
              prefHeight="520"
              spacing="24">

            <padding>
                <Insets top="28" right="36" bottom="28" left="36"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="18">
                <children>
                    <StackPane minWidth="64"
                               minHeight="64"
                               prefWidth="64"
                               prefHeight="64">
                        <children>
                            <Circle radius="22"
                                    fill="TRANSPARENT"
                                    strokeWidth="2"/>
                        </children>
                    </StackPane>
                    <Label text="Create an account"/>
                </children>
            </HBox>

            <!-- Forms stacked in the same spot -->
            <StackPane>
                <children>

                    <!-- Student form -->
                    <GridPane hgap="28" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <children>
                            <TextField fx:id="nameField"
                                       promptText="Full Name"
                                       GridPane.rowIndex="0"
                                       GridPane.columnIndex="0"/>

                            <ComboBox fx:id="levelComboBox"
                                      promptText="Level"
                                      GridPane.rowIndex="0"
                                      GridPane.columnIndex="1"/>

                            <TextField fx:id="passwordField"
                                       promptText="Password"
                                       GridPane.rowIndex="1"
                                       GridPane.columnIndex="0"/>

                            <ComboBox fx:id="programComboBox"
                                      promptText="Program"
                                      GridPane.rowIndex="1"
                                      GridPane.columnIndex="1"/>

                            <TextField fx:id="studentIdField"
                                       promptText="Student ID"
                                       GridPane.rowIndex="2"
                                       GridPane.columnIndex="0"/>

                            <CheckComboBox fx:id="completedRequisitesComboBox"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="1"/>

                            <ComboBox fx:id="collegeComboBox"
                                      promptText="College"
                                      GridPane.rowIndex="3"
                                      GridPane.columnIndex="0"/>

                            <DatePicker fx:id="startDatePicker"
                                        promptText="Start date"
                                        GridPane.rowIndex="3"
                                        GridPane.columnIndex="1"/>

                            <ComboBox fx:id="majorComboBox"
                                      promptText="Major"
                                      GridPane.rowIndex="4"
                                      GridPane.columnIndex="0"/>

                            <DatePicker fx:id="endDatePicker"
                                        promptText="End date"
                                        GridPane.rowIndex="4"
                                        GridPane.columnIndex="1"/>

                            <ComboBox fx:id="degreeComboBox"
                                      promptText="Pursuing Degree"
                                      GridPane.rowIndex="5"
                                      GridPane.columnIndex="0"/>

                            <TextField fx:id="emailField"
                                       promptText="Email"
                                       GridPane.rowIndex="5"
                                       GridPane.columnIndex="1"/>

                            <ComboBox fx:id="statusComboBox"
                                      promptText="Status"
                                      GridPane.rowIndex="6"
                                      GridPane.columnIndex="0"/>

                            <TextField fx:id="phoneField"
                                       promptText="Phone number"
                                       GridPane.rowIndex="6"
                                       GridPane.columnIndex="1"/>

                            <ComboBox fx:id="locationComboBox"
                                      promptText="Location"
                                      GridPane.rowIndex="7"
                                      GridPane.columnIndex="0"/>
                        </children>
                    </GridPane>

                    <!-- Admin form (same position, initially hidden if you want) -->
                </children>
            </StackPane>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Buttons -->
            <HBox alignment="CENTER_RIGHT" spacing="16">
                <children>
                    <Button fx:id="cancelBtn"
                            text="Cancel"
                            onAction="#handleCancel"/>
                    <Button fx:id="submitBtn"
                            text="Submit"
                            onAction="#handleSubmit"/>
                </children>
            </HBox>

        </VBox>
    </children>
</StackPane>

