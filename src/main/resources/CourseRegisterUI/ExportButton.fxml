<?import javafx.scene.control.Button?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.HBox?>
<HBox fx:id="exportHBox" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CourseRegisterUI.controllers.ExportButtonController">
    <Button fx:id="exportBtn" mnemonicParsing="false" style="-fx-background-color: white; -fx-border-color: white;" text="Export"
             textFill="#1f9ec1" onAction="#handleExportButton">
        <font>
            <Font name="System Bold" size="12.0"/>
        </font>
    </Button>
</HBox>
