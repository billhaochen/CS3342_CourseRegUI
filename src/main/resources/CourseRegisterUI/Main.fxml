<?import javafx.scene.layout.*?>
<?import javafx.scene.control.MenuBar?>

<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Button?>
<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="CourseRegisterUI.CourseController">
    <MenuBar fx:id="menuBar"/>
    <BorderPane prefHeight="10.0" prefWidth="640.0" style="-fx-background-color: white;" BorderPane.alignment="CENTER">
        <left>
            <HBox fx:id="userIcon"/>
        </left>
        <right>
            <HBox fx:id="exportButton" BorderPane.alignment="TOP_RIGHT"/>
        </right>
    </BorderPane>
    <SplitPane dividerPositions="0.35" VBox.vgrow="ALWAYS">
        <VBox fx:id="courseListPane"/>
        <BorderPane fx:id="schedulePane"/>
    </SplitPane>
</VBox>
