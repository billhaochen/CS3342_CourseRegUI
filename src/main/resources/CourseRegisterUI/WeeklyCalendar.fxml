<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="CourseRegisterUI.controllers.WeeklyCalendarController"
            style="-fx-background-color: #f5f5f5; -fx-padding: 10;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 15 0 15 0;">
            <Button fx:id="prevWeek" text="←" prefWidth="40"/>
            <Label fx:id="weekTitle" text="Feb 23 - Mar 1, 2026" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <Button fx:id="nextWeek" text="→" prefWidth="40"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="todayBtn" text="Today" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- FIXED: Single GridPane for everything -->
    <center>
        <ScrollPane fx:id="mainScroll" fitToWidth="true">
            <GridPane fx:id="mainGrid" hgap="1" vgap="1" style="-fx-padding: 0; -fx-background-color: transparent;">
                <!-- Headers row will be row 0, time slots start at row 1 -->
            </GridPane>
        </ScrollPane>
    </center>
</BorderPane>
